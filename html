<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>かな — Learn Japanese from Zero</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400&family=Noto+Sans+TC:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root, [data-theme="dark"] {
  --bg: #0e0e0f; --bg2: #161618; --bg3: #1e1e21; --bg4: #27272b;
  --border: rgba(255,255,255,0.07); --border2: rgba(255,255,255,0.13);
  --text: #f0ede8; --text2: #9e9b96; --text3: #5c5a56;
  --red: #e5534b; --red-light: rgba(229,83,75,0.12); --red-glow: rgba(229,83,75,0.25);
  --green: #3fb950; --green-bg: rgba(63,185,80,0.12);
  --yellow: #d29922; --yellow-bg: rgba(210,153,34,0.12);
  --blue: #4a90e2; --blue-bg: rgba(74,144,226,0.1);
}
[data-theme="light"] {
  --bg: #fafaf8; --bg2: #ffffff; --bg3: #f1f0ed; --bg4: #e5e4e0;
  --border: rgba(0,0,0,0.08); --border2: rgba(0,0,0,0.15);
  --text: #1a1a1d; --text2: #5a5a5a; --text3: #9a9a9a;
  --red: #c0392b; --red-light: rgba(192,57,43,0.08); --red-glow: rgba(192,57,43,0.18);
  --green: #2d7a3e; --green-bg: rgba(45,122,62,0.1);
  --yellow: #a87413; --yellow-bg: rgba(168,116,19,0.1);
  --blue: #2c6cb0; --blue-bg: rgba(44,108,176,0.1);
}

:root {
  --serif: 'Noto Serif JP', 'Noto Sans TC', serif;
  --sans: 'Inter', 'Noto Sans TC', system-ui, sans-serif;
  --radius: 10px;
  --radius-lg: 16px;
}

html { scroll-behavior: smooth; }
body {
  background: var(--bg); color: var(--text);
  font-family: var(--sans); font-size: 15px; line-height: 1.6;
  min-height: 100vh; -webkit-font-smoothing: antialiased;
  transition: background 0.25s, color 0.25s;
}
[lang="zh"] body, body[data-lang="zh"] { font-family: 'Noto Sans TC', 'Inter', system-ui, sans-serif; }

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 3px; }

.app { display: flex; min-height: 100vh; }

/* ─── SIDEBAR ─── */
.sidebar {
  width: 230px; flex-shrink: 0;
  background: var(--bg2); border-right: 1px solid var(--border);
  position: fixed; top: 0; left: 0; bottom: 0;
  display: flex; flex-direction: column; z-index: 50;
  transition: background 0.25s, border-color 0.25s;
}
.logo { padding: 1.5rem 1.25rem 1rem; border-bottom: 1px solid var(--border); }
.logo-jp { font-family: var(--serif); font-size: 26px; font-weight: 300; color: var(--red); line-height: 1; }
.logo-en { font-size: 11px; color: var(--text3); letter-spacing: 0.12em; margin-top: 5px; }

.progress-mini { padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); }
.prog-label { display: flex; justify-content: space-between; font-size: 11px; color: var(--text3); margin-bottom: 6px; letter-spacing: 0.04em; }
.prog-track { height: 3px; background: var(--bg4); border-radius: 2px; overflow: hidden; }
.prog-fill { height: 100%; background: var(--red); border-radius: 2px; transition: width 0.5s ease; }

.nav { padding: 0.75rem 0; flex: 1; overflow-y: auto; }
.nav-section-title { font-size: 10px; color: var(--text3); letter-spacing: 0.12em; padding: 0.75rem 1.25rem 0.35rem; text-transform: uppercase; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 1.25rem; cursor: pointer;
  color: var(--text2); font-size: 13px; font-weight: 400;
  transition: all 0.15s; border-left: 2px solid transparent;
  user-select: none;
}
.nav-item:hover { color: var(--text); background: var(--bg3); }
.nav-item.active { color: var(--text); background: var(--red-light); border-left-color: var(--red); }
.nav-item .icon { font-size: 15px; width: 18px; text-align: center; flex-shrink: 0; }
.nav-badge {
  margin-left: auto; font-size: 10px; padding: 2px 7px;
  border-radius: 999px; background: var(--bg4);
  color: var(--text3); font-weight: 500;
}
.nav-badge.done { background: var(--green-bg); color: var(--green); }

.sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid var(--border); font-size: 11px; color: var(--text3); }

/* ─── MAIN ─── */
.main { margin-left: 230px; flex: 1; min-height: 100vh; }

/* ─── TOP BAR ─── */
.topbar {
  padding: 1rem 1.5rem; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  background: var(--bg); position: sticky; top: 0; z-index: 40;
  gap: 1rem; flex-wrap: wrap;
  transition: background 0.25s, border-color 0.25s;
}
.topbar-title { font-size: 17px; font-weight: 500; }
.topbar-sub { font-size: 12px; color: var(--text3); margin-top: 2px; }

.topbar-controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

.script-toggle, .lang-toggle {
  display: flex; border: 1px solid var(--border2); border-radius: var(--radius);
  overflow: hidden; background: var(--bg2);
}
.script-btn, .lang-btn {
  padding: 6px 14px; font-size: 12px; font-weight: 500;
  background: transparent; border: none; cursor: pointer;
  color: var(--text2); transition: all 0.15s; font-family: inherit;
}
.script-btn.active, .lang-btn.active { background: var(--red); color: #fff; }
.script-btn:hover:not(.active), .lang-btn:hover:not(.active) { background: var(--bg3); color: var(--text); }

.icon-btn {
  width: 34px; height: 34px;
  border: 1px solid var(--border2); border-radius: var(--radius);
  background: var(--bg2); cursor: pointer; color: var(--text2);
  display: flex; align-items: center; justify-content: center;
  transition: all 0.15s; font-size: 15px;
}
.icon-btn:hover { background: var(--bg3); color: var(--text); }

/* ─── PAGE CONTENT ─── */
.page { display: none; padding: 1.75rem; max-width: 1200px; }
.page.active { display: block; }

/* ─── LESSON INTRO ─── */
.lesson-intro {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 1.5rem;
  margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: 1.5rem;
}
.lesson-intro-icon {
  font-family: var(--serif); font-size: 52px;
  color: var(--red); line-height: 1; flex-shrink: 0;
}
.lesson-intro h2 { font-size: 18px; font-weight: 500; margin-bottom: 4px; }
.lesson-intro p { font-size: 13px; color: var(--text2); line-height: 1.7; }

/* ─── KANA GRID ─── */
.row-group { margin-bottom: 2rem; }
.row-title {
  font-size: 11px; color: var(--text3); letter-spacing: 0.12em;
  text-transform: uppercase; margin-bottom: 0.9rem;
  display: flex; align-items: center; gap: 0.75rem;
}
.row-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

.kana-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
.kana-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 14px 8px;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  cursor: pointer; transition: all 0.18s; user-select: none;
  position: relative; min-height: 90px; justify-content: center;
}
.kana-card:hover { border-color: var(--border2); background: var(--bg3); transform: translateY(-2px); }
.kana-card.learned { border-color: rgba(229,83,75,0.35); background: var(--red-light); }
.kana-card.selected { border: 1.5px solid var(--red); background: var(--red-light); }
.kana-card.empty { visibility: hidden; pointer-events: none; }
.kana-char { font-family: var(--serif); font-size: 30px; line-height: 1; color: var(--text); }
.kana-card.learned .kana-char { color: var(--red); }
.kana-rom { font-size: 11px; color: var(--text3); font-weight: 500; letter-spacing: 0.06em; }
.kana-dot {
  position: absolute; top: 6px; right: 6px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--red); display: none;
}
.kana-card.learned .kana-dot { display: block; }
.kana-audio {
  position: absolute; top: 4px; left: 4px;
  width: 22px; height: 22px;
  border: 1px solid var(--border2); border-radius: 50%;
  background: var(--bg2); cursor: pointer;
  color: var(--red); font-size: 9px;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.15s, background 0.15s;
}
.kana-card:hover .kana-audio { opacity: 1; }
.kana-audio:hover { background: var(--red); color: #fff; }

/* ─── DETAIL PANEL ─── */
.detail-panel {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 0;
  margin-bottom: 1.5rem; overflow: hidden;
  display: none; animation: slideDown 0.2s ease;
}
.detail-panel.open { display: block; }
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}
.detail-inner { display: grid; grid-template-columns: 180px 1fr 1fr; gap: 0; }
.detail-char-col {
  background: var(--red-light); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 1.5rem 1rem; gap: 8px;
}
.detail-big { font-family: var(--serif); font-size: 72px; color: var(--red); line-height: 1; }
.detail-rom { font-size: 20px; font-weight: 300; color: var(--text2); letter-spacing: 0.04em; }
.detail-info-col, .detail-stroke-col { padding: 1.25rem 1.25rem; }
.detail-info-col { border-right: 1px solid var(--border); }
.detail-section-title {
  font-size: 10px; color: var(--text3); letter-spacing: 0.1em;
  text-transform: uppercase; margin-bottom: 0.75rem;
}
.pronunciation-note { font-size: 13px; color: var(--text2); line-height: 1.7; margin-bottom: 1rem; }
.example-word {
  background: var(--bg3); border-radius: var(--radius);
  padding: 10px 14px; margin-bottom: 8px;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.example-word-text { flex: 1; }
.ex-jp { font-family: var(--serif); font-size: 18px; color: var(--text); }
.ex-rom { font-size: 11px; color: var(--text3); margin-top: 2px; }
.ex-mean { font-size: 11px; color: var(--text2); margin-top: 2px; }
.stroke-tip { font-size: 13px; color: var(--text2); line-height: 1.7; margin-bottom: 0.75rem; }
.mark-btn {
  padding: 7px 16px; border-radius: var(--radius); font-family: inherit;
  font-size: 12px; font-weight: 500; cursor: pointer; border: 1px solid var(--border2);
  color: var(--text2); background: var(--bg3); transition: all 0.15s; letter-spacing: 0.04em;
}
.mark-btn:hover { background: var(--bg4); color: var(--text); }
.mark-btn.marked { background: var(--red); color: #fff; border-color: var(--red); }
.close-detail {
  display: block; text-align: right; padding: 8px 12px;
  border-top: 1px solid var(--border); cursor: pointer;
  font-size: 11px; color: var(--text3); transition: color 0.15s;
}
.close-detail:hover { color: var(--text); }

/* ─── AUDIO + PITCH ─── */
.audio-btn {
  display: inline-flex; align-items: center; justify-content: center;
  width: 24px; height: 24px;
  border: 1px solid var(--border2); border-radius: 50%;
  background: var(--bg2); cursor: pointer;
  color: var(--red); font-size: 9px;
  transition: all 0.15s; flex-shrink: 0;
  font-family: inherit;
}
.audio-btn:hover { background: var(--red); color: #fff; }
.audio-btn.lg { width: 30px; height: 30px; font-size: 11px; }

.pitch-viz {
  display: inline-flex; gap: 3px; align-items: flex-end;
  height: 36px; padding: 2px 4px;
  border: 1px solid var(--border); border-radius: var(--radius);
  background: var(--bg);
}
.pitch-mora {
  display: flex; flex-direction: column; align-items: center;
  gap: 2px; padding: 2px 1px;
}
.pitch-bar { width: 16px; border-radius: 2px; transition: height 0.2s; }
.pitch-bar.h { background: var(--red); height: 18px; }
.pitch-bar.l { background: var(--bg4); height: 7px; }
.pitch-kana { font-size: 10px; color: var(--text2); font-family: var(--serif); }
.pitch-num {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 22px; height: 22px; padding: 0 6px;
  background: var(--red); color: #fff;
  border-radius: 999px; font-size: 11px; font-weight: 600;
}
.pitch-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

/* ─── DAKUTEN PAGE ─── */
.dakuten-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
.dk-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 8px; text-align: center; cursor: pointer; transition: all 0.15s; }
.dk-card:hover { border-color: var(--border2); background: var(--bg3); }
.dk-pair { display: flex; justify-content: center; align-items: baseline; gap: 6px; }
.dk-orig { font-family: var(--serif); font-size: 20px; color: var(--text3); }
.dk-arrow { font-size: 12px; color: var(--text3); }
.dk-new { font-family: var(--serif); font-size: 28px; color: var(--text); }
.dk-rom { font-size: 11px; color: var(--text3); margin-top: 4px; letter-spacing: 0.04em; }

/* ─── COMBO PAGE ─── */
.combo-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.combo-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 10px; text-align: center; cursor: pointer; transition: all 0.15s; }
.combo-card:hover { border-color: var(--border2); background: var(--bg3); }
.combo-chars { font-family: var(--serif); font-size: 22px; color: var(--text); }
.combo-chars span { font-size: 14px; vertical-align: super; color: var(--text3); }
.combo-rom { font-size: 11px; color: var(--text3); margin-top: 5px; }

/* ─── CHART PAGE ─── */
.chart-table { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; border-collapse: collapse; width: 100%; }
.chart-table th, .chart-table td { border: 1px solid var(--border); padding: 0; text-align: center; min-width: 70px; }
.chart-table th { background: var(--bg3); font-size: 10px; color: var(--text3); letter-spacing: 0.08em; padding: 8px 6px; text-transform: uppercase; }
.chart-cell { padding: 10px 6px; cursor: pointer; transition: background 0.15s; display: flex; flex-direction: column; align-items: center; gap: 3px; }
.chart-cell:hover { background: var(--bg4); }
.chart-cell.learned { background: var(--red-light); }
.chart-cell .cc { font-family: var(--serif); font-size: 22px; color: var(--text); }
.chart-cell.learned .cc { color: var(--red); }
.chart-cell .cr { font-size: 10px; color: var(--text3); }

/* ─── QUIZ + FLASHCARDS (existing) ─── */
.quiz-container { max-width: 560px; margin: 0 auto; }
.quiz-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
.quiz-stat { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 16px; text-align: center; }
.quiz-stat-num { font-size: 22px; font-weight: 600; }
.quiz-stat-num.green { color: var(--green); }
.quiz-stat-num.red { color: var(--red); }
.quiz-stat-num.yellow { color: var(--yellow); }
.quiz-stat-label { font-size: 11px; color: var(--text3); margin-top: 2px; }

.quiz-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem; text-align: center; margin-bottom: 1.5rem; }
.quiz-prompt-label { font-size: 11px; color: var(--text3); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1rem; }
.quiz-char { font-family: var(--serif); font-size: 100px; line-height: 1; color: var(--text); margin-bottom: 0.5rem; display: block; }
.quiz-char.romaji-mode { font-family: var(--sans); font-size: 52px; font-weight: 300; }
.quiz-mode-switch { display: flex; gap: 8px; justify-content: center; margin-bottom: 1.5rem; flex-wrap: wrap; }
.mode-btn { padding: 6px 14px; font-size: 12px; font-weight: 500; border: 1px solid var(--border2); border-radius: 999px; background: transparent; cursor: pointer; color: var(--text2); font-family: inherit; transition: all 0.15s; }
.mode-btn.active { background: var(--bg3); color: var(--text); border-color: var(--border2); }
.choices-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1rem; }
.choice-btn { padding: 16px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg2); cursor: pointer; color: var(--text); font-size: 15px; font-weight: 400; font-family: inherit; transition: all 0.15s; }
.choice-btn.jp-choice { font-family: var(--serif); font-size: 28px; }
.choice-btn:hover:not(:disabled):not(.correct):not(.wrong) { border-color: var(--border2); background: var(--bg3); }
.choice-btn.correct { background: var(--green-bg); border-color: var(--green); color: var(--green); }
.choice-btn.wrong { background: rgba(229,83,75,0.12); border-color: var(--red); color: var(--red); }
.quiz-feedback { text-align: center; min-height: 22px; font-size: 14px; margin-bottom: 1rem; color: var(--text2); }
.quiz-next { width: 100%; padding: 13px; background: var(--red); color: #fff; border: none; border-radius: var(--radius); font-family: inherit; font-size: 14px; font-weight: 500; cursor: pointer; display: none; transition: opacity 0.15s; }
.quiz-next:hover { opacity: 0.88; }
.streak-bar { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px; font-size: 13px; color: var(--text3); margin-bottom: 1.5rem; }
.streak-flame { font-size: 18px; transition: transform 0.3s; }
.streak-bar.hot .streak-flame { transform: scale(1.3); }
.streak-bar.hot { color: var(--yellow); }

.flashcard-container { max-width: 480px; margin: 0 auto; text-align: center; }
.flashcard-wrap { perspective: 1200px; margin: 2rem auto; width: 320px; height: 220px; }
.flashcard { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform 0.5s ease; cursor: pointer; }
.flashcard.flipped { transform: rotateY(180deg); }
.flashcard-face { position: absolute; width: 100%; height: 100%; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg); backface-visibility: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
.flashcard-front .fc-char { font-family: var(--serif); font-size: 72px; color: var(--text); line-height: 1; }
.flashcard-back { transform: rotateY(180deg); }
.flashcard-back .fc-rom { font-size: 32px; font-weight: 300; color: var(--red); letter-spacing: 0.06em; }
.flashcard-back .fc-word { font-family: var(--serif); font-size: 22px; color: var(--text2); }
.flashcard-back .fc-mean { font-size: 13px; color: var(--text3); }
.fc-hint { font-size: 11px; color: var(--text3); }
.flashcard-nav { display: flex; gap: 10px; justify-content: center; margin-top: 1rem; }
.fc-btn { padding: 10px 24px; border: 1px solid var(--border2); border-radius: var(--radius); background: var(--bg2); color: var(--text2); cursor: pointer; font-family: inherit; font-size: 13px; font-weight: 500; transition: all 0.15s; }
.fc-btn:hover { background: var(--bg3); color: var(--text); }
.fc-btn.good { background: var(--green-bg); border-color: var(--green); color: var(--green); }
.fc-btn.skip { background: rgba(229,83,75,0.1); border-color: var(--red); color: var(--red); }
.fc-counter { font-size: 13px; color: var(--text3); margin-top: 1.5rem; }
.fc-progress { margin-top: 1rem; }

/* ─── PITCH PAGE ─── */
.pitch-section { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 1.25rem; }
.pitch-section h3 { font-size: 15px; font-weight: 500; margin-bottom: 10px; color: var(--text); }
.pitch-section p { font-size: 13px; color: var(--text2); line-height: 1.8; margin-bottom: 12px; }
.pitch-type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px; }
.pitch-type-card { background: var(--bg3); border-radius: var(--radius); padding: 14px; }
.pitch-type-name { font-size: 12px; font-weight: 600; color: var(--red); margin-bottom: 6px; }
.pitch-type-desc { font-size: 12px; color: var(--text2); margin-bottom: 10px; line-height: 1.6; }
.pitch-example-row { display: flex; align-items: center; gap: 12px; padding: 8px 0; border-top: 1px solid var(--border); }
.pitch-example-row:first-of-type { border-top: none; }
.pitch-example-word { font-family: var(--serif); font-size: 17px; color: var(--text); min-width: 70px; }
.pitch-example-meaning { font-size: 11px; color: var(--text3); margin-left: auto; }

/* ─── KANJI PAGE ─── */
.kanji-hero {
  background: linear-gradient(135deg, var(--red-light) 0%, var(--bg2) 100%);
  border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 2rem 1.5rem; margin-bottom: 1.5rem; text-align: center;
}
.kanji-hero-char { font-family: var(--serif); font-size: 96px; color: var(--red); line-height: 1; }
.kanji-hero-sub { font-size: 13px; color: var(--text2); margin-top: 10px; }
