function t(key) { return T[currentLang][key] || T.en[key] || key; }

function applyI18n() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (T[currentLang][key]) {
      el.innerHTML = T[currentLang][key];
    }
  });
  document.documentElement.lang = currentLang === 'zh' ? 'zh-TW' : 'en';
  document.body.setAttribute('data-lang', currentLang);
}

// Web Speech API for Japanese audio
let jaVoice = null;
function loadVoices() {
  if (!('speechSynthesis' in window)) return;
  const voices = speechSynthesis.getVoices();
  jaVoice = voices.find(v => v.lang && (v.lang === 'ja-JP' || v.lang.startsWith('ja'))) || null;
}
if ('speechSynthesis' in window) {
  loadVoices();
  speechSynthesis.onvoiceschanged = loadVoices;
}

function speak(text, e) {
  if (e && e.stopPropagation) e.stopPropagation();
  if (!('speechSynthesis' in window)) {
    alert(currentLang === 'zh' ? '此瀏覽器不支援語音合成。' : 'Speech synthesis not supported in this browser.');
    return;
  }
  speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'ja-JP';
  u.rate = 0.85;
  if (jaVoice) u.voice = jaVoice;
  speechSynthesis.speak(u);
}

// Split hiragana into morae (small kana ゃゅょ etc combine with preceding)
function splitMorae(hira) {
  const combineWithPrev = 'ぁぃぅぇぉゃゅょゎァィゥェォャュョヮ';
  const result = [];
  for (let i = 0; i < hira.length; i++) {
    const ch = hira[i];
    if (combineWithPrev.includes(ch) && result.length > 0) {
      result[result.length - 1] += ch;
    } else {
      result.push(ch);
    }
  }
  return result;
}

// Get pitch pattern array (h/l) for a mora-count and accent type
function getPitchPattern(moraCount, accentType) {
  const arr = [];
  for (let i = 0; i < moraCount; i++) {
    if (accentType === 0) arr.push(i === 0 ? 'l' : 'h');
    else if (accentType === 1) arr.push(i === 0 ? 'h' : 'l');
    else {
      if (i === 0) arr.push('l');
      else if (i < accentType) arr.push('h');
      else arr.push('l');
    }
  }
